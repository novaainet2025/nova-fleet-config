        "prompt": {
          "desc": "비대화형 에이전트 실행 (코드 리뷰, 버그 분석)",
          "cmd": ["cursor-agent", "--print", "{prompt}"],
          "options": {
            "--output-format json": "JSON 출력",
            "--output-format stream-json": "스트리밍 JSON",
            "--model sonnet-4": "모델 지정",
            "--force": "모든 커맨드 허용 (--yolo)",
