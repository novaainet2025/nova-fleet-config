  "providers": {
    "codex": {
      "name": "OpenAI Codex CLI",
      "binary": "/opt/homebrew/bin/codex",
      "type": "cli",
      "role": "Engineer",
      "score": 83,
      "headless": true,
      "tools": {
        "exec": {
          "desc": "코드 작업 비대화형 실행 (버그픽스, 구현, 수정)",
          "cmd": ["codex", "exec", "{prompt}"],
          "options": {
            "--config model=o4-mini": "모델 지정",
            "--config sandbox_permissions=[\"disk-full-read-access\"]": "디스크 전체 읽기 허용",
            "--enable auto-edit": "자동 편집 허용"
          },
          "example": "codex exec 'Fix the null pointer bug in src/main.ts'"
        },
        "review": {
          "desc": "코드 리뷰 비대화형 실행",
          "cmd": ["codex", "review", "{prompt}"],
          "options": {
            "--uncommitted": "스테이징/언스테이징/언트랙 변경 리뷰"
          },
          "example": "codex review 'Security review for auth module' --uncommitted"
        },
        "apply": {
          "desc": "최근 Codex 에이전트 diff를 git apply로 적용",
          "cmd": ["codex", "apply"],
          "example": "codex apply"
        },
        "mcp_server": {
          "desc": "Codex를 MCP 서버로 시작 (stdio)",
          "cmd": ["codex", "mcp-server"],
          "example": "codex mcp-server"
        }
      }
    },
    "opencode": {
      "name": "OpenCode",
      "binary": "/opt/homebrew/bin/opencode",
      "type": "cli",
      "role": "Architect",
      "score": 90,
