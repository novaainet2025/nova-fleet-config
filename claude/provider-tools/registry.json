          "desc": "사용 가능한 모델 목록",
          "cmd": ["opencode", "models"],
          "example": "opencode models"
        },
        "providers": {
          "desc": "AI 프로바이더 설정 관리",
          "cmd": ["opencode", "providers"],
          "example": "opencode providers"
