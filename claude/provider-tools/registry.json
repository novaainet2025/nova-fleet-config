          },
          "example": "cursor-agent --print 'Review auth.ts for security issues'"
        },
        "plan": {
          "desc": "읽기 전용 계획 모드 (분석, 제안만, 편집 없음)",
          "cmd": ["cursor-agent", "--print", "--mode", "plan", "{prompt}"],
          "example": "cursor-agent --print --mode plan 'Plan refactoring for UserService'"
        },
        "ask": {
          "desc": "Q&A 모드 (질문/설명, 읽기 전용)",
          "cmd": ["cursor-agent", "--print", "--mode", "ask", "{prompt}"],
          "example": "cursor-agent --print --mode ask 'How does the auth middleware work?'"
        },
        "models": {
          "desc": "사용 가능한 모델 목록",
          "cmd": ["cursor-agent", "--list-models"],
          "example": "cursor-agent --list-models"
        }
      }
    },
